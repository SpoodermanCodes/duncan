generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String          @id @default(cuid())
  username  String          @unique
  email     String          @unique
  password  String
  createdAt DateTime        @default(now())
  orders    Order[]
  tickets   SupportTicket[]
}

model Product {
  id         String   @id @default(cuid())
  name       String
  brand      String
  price      Float
  oldPrice   Float?
  memory     String
  boostClock String
  imageUrl   String
  stripeId   String?
  orders     Order[]
}

model Order {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String?
  gpu       String
  problem   String
  details   String
  name      String
  email     String
  phone     String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model NewsArticle {
  id        String   @id @default(cuid())
  title     String
  content   String
  imageUrl  String
  createdAt DateTime @default(now())
}
